{
  "name": "daylight-calendar-card",
  "version": "0.2.0",
  "description": "A clean, family-friendly calendar card for Home Assistant",
  "main": "daylight-calendar-card.js",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch --environment BUILD:dev",
    "dev:live": "rollup -c --watch --environment BUILD:live",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "calendar",
    "hacs"
  ],
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "rollup": "^4.30.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "lit": "^3.2.0"
  }
}
